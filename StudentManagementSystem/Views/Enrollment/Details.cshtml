@model StudentManagementSystem.Models.Enrollment

@{
    ViewData["Title"] = "Enrollment Details";
}

<div class="container my-5">
    <h2 class="mb-4"><i class="fas fa-clipboard-list me-2"></i>Enrollment Details</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3"><i class="fas fa-user-graduate me-2"></i>Student</dt>
                <dd class="col-sm-9">@Model.Student?.StudentName</dd>

                <dt class="col-sm-3"><i class="fas fa-book me-2"></i>Course</dt>
                <dd class="col-sm-9">@Model.Course?.CourseName</dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model?.EnrollmentId" class="btn btn-warning me-2">
                <i class="fas fa-edit me-1"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to List
            </a>
        </div>
    </div>
</div>
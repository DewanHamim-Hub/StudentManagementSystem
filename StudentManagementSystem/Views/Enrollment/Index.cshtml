@model IEnumerable<StudentManagementSystem.Models.Enrollment>

@{
    ViewData["Title"] = "Enrollment Management";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-clipboard-list me-2"></i>Enrollment Management</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus-circle me-1"></i>Create New Enrollment
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover shadow-sm text-center align-middle">
            <thead class="bg-dark text-white">
                <tr>
                    <th><i class="fas fa-user-graduate me-1"></i>Student</th>
                    <th><i class="fas fa-book-open me-1"></i>Course</th>
                    <th style="width: 260px;"><i class="fas fa-tools me-1"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Student?.StudentName</td>
                        <td>@item.Course?.CourseName</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.EnrollmentId" class="btn btn-sm btn-warning me-1">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.EnrollmentId" class="btn btn-sm btn-info me-1 text-white">
                                <i class="fas fa-info-circle me-1"></i>Details
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.EnrollmentId" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash-alt me-1"></i>Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
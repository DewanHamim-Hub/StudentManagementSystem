@model IEnumerable<StudentManagementSystem.Models.User>

@{
    ViewData["Title"] = "User Management";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-users-cog me-2"></i>User Management</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus-circle me-1"></i>Create New User
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover shadow-sm">
            <thead class="bg-dark text-white">
                <tr>
                    <th><i class="fas fa-user me-1"></i>Username</th>
                    <th><i class="fas fa-user-tag me-1"></i>Role</th>
                    <th class="text-end" style="width: 240px;"><i class="fas fa-tools me-1"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.UserName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Role)</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end">
                                <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-primary me-1">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-info me-1 text-white">
                                    <i class="fas fa-info-circle me-1"></i>Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash-alt me-1"></i>Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
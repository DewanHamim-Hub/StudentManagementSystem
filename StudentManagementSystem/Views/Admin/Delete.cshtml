@model StudentManagementSystem.Models.User

@{
    ViewData["Title"] = "Delete User";
}

<div class="container my-5">
    <h2 class="mb-3 text-danger">
        <i class="fas fa-trash-alt me-2"></i>Delete User
    </h2>

    <div class="alert alert-warning d-flex align-items-center" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>
        Are you sure you want to delete this teacher?
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3"><i class="fas fa-user me-2"></i>User Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.UserName)</dd>

                <dt class="col-sm-3"><i class="fas fa-user-tag me-2"></i>Role</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Role)</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" class="mt-3 d-flex justify-content-start gap-2">
        <input type="hidden" asp-for="UserId" />
        <button type="submit" class="btn btn-danger">
            <i class="fas fa-trash-alt me-1"></i>Confirm Delete
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back to List
        </a>
    </form>
</div>
@model StudentManagementSystem.Models.User

@{
    ViewData["Title"] = "Edit";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">
                        <i class="fas fa-user-edit me-2"></i>Edit User
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="UserId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3 input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="UserName" class="form-control" placeholder="Username" />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger mb-2 d-block"></span>

                        <div class="mb-3 input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger mb-2 d-block"></span>

                        <div class="mb-3 input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-user-tag"></i>
                            </span>
                            <select asp-for="Role" class="form-select">
                                <option value="">-- Select Role --</option>
                                <option>Admin</option>
                                <option>Teacher</option>
                                <option>Student</option>
                            </select>
                        </div>
                        <span asp-validation-for="Role" class="text-danger mb-3 d-block"></span>

                        <button type="submit" class="btn btn-success w-100 mt-2">
                            <i class="fas fa-save me-1"></i>Save Changes
                        </button>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none">
                    <i class="fas fa-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
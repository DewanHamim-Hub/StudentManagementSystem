@model StudentManagementSystem.Models.User

@{
    ViewData["Title"] = "User Details";
}

<div class="container my-5">
    <h2 class="mb-4"><i class="fas fa-id-card-alt me-2"></i>User Details</h2>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3"><i class="fas fa-user me-2"></i>Username</dt>
                <dd class="col-sm-9">@Model.UserName</dd>

                <dt class="col-sm-3"><i class="fas fa-user-tag me-2"></i>Role</dt>
                <dd class="col-sm-9">@Model.Role</dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model?.UserId" class="btn btn-warning me-2">
                <i class="fas fa-edit me-1"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to List
            </a>
        </div>
    </div>
</div>
@model StudentManagementSystem.Models.Student

@{
    ViewData["Title"] = "Delete";
}

<div class="container my-4">
    <h2 class="mb-3">
        <i class="fas fa-trash-alt me-2 text-danger"></i>Delete Student
    </h2>

    <div class="alert alert-warning" role="alert">
        Are you sure you want to delete this student?
    </div>

    <div class="card shadow mb-4 mx-auto" style="max-width: 90vw;">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 fw-bold">
                    <i class="fas fa-user me-1 text-primary"></i> Username
                </dt>
                <dd class="col-sm-8">@Model.User?.UserName</dd>

                <dt class="col-sm-4 fw-bold">
                    <i class="fas fa-id-card me-1 text-primary"></i> Student Name
                </dt>
                <dd class="col-sm-8">@Model.StudentName</dd>

                <dt class="col-sm-4 fw-bold">
                    <i class="fas fa-envelope me-1 text-primary"></i> Email
                </dt>
                <dd class="col-sm-8">@Model.Email</dd>

                <dt class="col-sm-4 fw-bold">
                    <i class="fas fa-building me-1 text-primary"></i> Department
                </dt>
                <dd class="col-sm-8">@Model.Department</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="StudentId" />
        <button type="submit" class="btn btn-danger">
            <i class="fas fa-check-circle me-1"></i> Confirm Delete
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </form>
</div>
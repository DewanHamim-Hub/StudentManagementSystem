@model IEnumerable<StudentManagementSystem.Models.Enrollment>

@{
    ViewData["Title"] = "My Enrolled Courses";
}

<div class="container my-5">
    <h2 class="mb-4 text-primary">
        <i class="fas fa-book-open me-2"></i>My Enrolled Courses
    </h2>

    <div class="table-responsive shadow rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>
                        <i class="fas fa-book me-1 text-secondary"></i>
                        Course Name
                    </th>
                    <th>
                        <i class="fas fa-chalkboard-teacher me-1 text-secondary"></i>
                        Teacher Name
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fs-5">@item.Course?.CourseName</td>
                        <td class="fs-5">@item.Course?.Teacher?.TeacherName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
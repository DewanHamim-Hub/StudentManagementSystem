@model IEnumerable<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Student Management";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-user-graduate me-2"></i>Student Management</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus-circle me-1"></i>Create New Student
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover shadow-sm">
            <thead class="bg-dark text-white">
                <tr>
                    <th class="text-start"><i class="fas fa-user me-1"></i>Username</th>
                    <th class="text-start"><i class="fas fa-id-card me-1"></i>Student Name</th>
                    <th class="text-start" style="width: 200px;"><i class="fas fa-envelope me-1"></i>Email</th>
                    <th class="text-start"><i class="fas fa-building me-1"></i>Department</th>
                    <th class="text-center" style="width: 260px;"><i class="fas fa-tools me-1"></i>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-start">@item.User?.UserName</td>
                        <td class="text-start">@item.StudentName</td>
                        <td class="text-start">@item.Email</td>
                        <td class="text-start">@item.Department</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-sm btn-warning me-1">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.StudentId" class="btn btn-sm btn-info me-1 text-white">
                                <i class="fas fa-info-circle me-1"></i>Details
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash-alt me-1"></i>Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@model StudentManagementSystem.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container my-5">
    <h2 class="mb-4"><i class="fas fa-user-graduate me-2"></i>Student Details</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3"><i class="fas fa-user me-2"></i>Username</dt>
                <dd class="col-sm-9">@Model.User?.UserName</dd>

                <dt class="col-sm-3"><i class="fas fa-id-card me-2"></i>Student Name</dt>
                <dd class="col-sm-9">@Model.StudentName</dd>

                <dt class="col-sm-3"><i class="fas fa-envelope me-2"></i>Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3"><i class="fas fa-building me-2"></i>Department</dt>
                <dd class="col-sm-9">@Model.Department</dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model?.StudentId" class="btn btn-warning me-2">
                <i class="fas fa-edit me-1"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to List
            </a>
        </div>
    </div>
</div>
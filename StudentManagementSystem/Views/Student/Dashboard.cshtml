@{
    ViewData["Title"] = "Student Dashboard";
}

<div style="display: flex; justify-content: space-between; align-items: center;">
    <h2>Welcome to Your Dashboard</h2>
    <form asp-controller="Account" asp-action="Logout" method="post" style="display: inline;">
        <button type="submit" class="btn btn-outline-danger">Logout</button>
    </form>
</div>

<hr />

<div class="row g-4">

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-user fa-3x text-primary me-4"></i>
                <div>
                    <h5 class="card-title">My Profile</h5>
                    <p class="card-text">View and update your personal information.</p>
                    <a asp-action="Profile" asp-controller="Student" class="btn btn-primary">
                        View Profile <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-book fa-3x text-success me-4"></i>
                <div>
                    <h5 class="card-title">Enrolled Courses</h5>
                    <p class="card-text">See all the courses you are currently enrolled in.</p>
                    <a asp-action="Enrollments" asp-controller="Student" class="btn btn-success">
                        View Courses <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-graduation-cap fa-3x text-warning me-4"></i>
                <div>
                    <h5 class="card-title">My Grades</h5>
                    <p class="card-text">Check your grades for all enrolled courses.</p>
                    <a asp-action="Grades" asp-controller="Student" class="btn btn-warning text-white">
                        View Grades <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>
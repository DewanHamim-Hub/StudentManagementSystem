@model StudentManagementSystem.Models.Grade

@{
    ViewData["Title"] = "Edit Grade";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4">
                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Grade</h4>
                </div>
                <div class="card-body px-5 py-4">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="GradeId" />

                        <div class="mb-3">
                            <label asp-for="EnrollmentId" class="form-label fw-semibold">@Html.DisplayNameFor(model => model.EnrollmentId)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user-graduate"></i></span>
                                <select asp-for="EnrollmentId" class="form-select" asp-items="ViewBag.EnrollmentId">
                                    <option value="">-- Select Enrollment --</option>
                                </select>
                            </div>
                            <span asp-validation-for="EnrollmentId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="LetterGrade" class="form-label fw-semibold">@Html.DisplayNameFor(model => model.LetterGrade)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-pen"></i></span>
                                <input asp-for="LetterGrade" class="form-control" />
                            </div>
                            <span asp-validation-for="LetterGrade" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Back to List link outside card -->
            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none">
                    <i class="fas fa-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
@model IEnumerable<StudentManagementSystem.Models.Course>

@{
    ViewData["Title"] = "My Courses";
}

<div class="container my-5">
    <h1 class="text-center mb-4">
        <i class="fas fa-book-open me-2 text-primary"></i>My Assigned Courses
    </h1>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle me-2"></i>
            You have not been assigned to any courses.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>
                            <i class="fas fa-book me-1"></i> Course Name
                        </th>
                        <th>
                            <i class="fas fa-building me-1"></i> Department
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td>
                                <i class="fas fa-angle-right text-secondary me-2"></i>
                                @course.CourseName
                            </td>
                            <td>@course.Teacher?.Department</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
@model StudentManagementSystem.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container my-5">
    <h2 class="mb-4"><i class="fas fa-book me-2"></i>Course Details</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3"><i class="fas fa-book me-2"></i>Course Name</dt>
                <dd class="col-sm-9">@Model.CourseName</dd>

                <dt class="col-sm-3"><i class="fas fa-chalkboard-teacher me-2"></i>Teacher</dt>
                <dd class="col-sm-9">@Model.Teacher?.TeacherName</dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model?.CourseId" class="btn btn-warning me-2">
                <i class="fas fa-edit me-1"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to List
            </a>
        </div>
    </div>
</div>
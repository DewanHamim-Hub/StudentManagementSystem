@model StudentManagementSystem.Models.Course

@{
    ViewData["Title"] = "Delete";
}

<div class="container my-4">
    <h2 class="mb-3">
        <i class="fas fa-trash-alt me-2 text-danger"></i>Delete Course
    </h2>

    <div class="alert alert-warning" role="alert">
        Are you sure you want to delete this course?
    </div>

    <div class="card shadow mb-4 mx-auto" style="max-width: 90vw;">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 fw-bold">
                    <i class="fas fa-book me-1 text-primary"></i> Course Name
                </dt>
                <dd class="col-sm-8">@Model.CourseName</dd>

                <dt class="col-sm-4 fw-bold">
                    <i class="fas fa-chalkboard-teacher me-1 text-primary"></i> Teacher
                </dt>
                <dd class="col-sm-8">@Model.Teacher?.TeacherName</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="CourseId" />
        <button type="submit" class="btn btn-danger">
            <i class="fas fa-check-circle me-1"></i> Confirm Delete
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </form>
</div>
@model StudentManagementSystem.Models.Teacher

@{
    ViewData["Title"] = "Create";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">
                        <i class="fas fa-chalkboard-teacher me-2"></i>Create New Teacher
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3 input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-user"></i>
                            </span>
                            <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
                        </div>

                        <div class="mb-3 input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-id-card"></i>
                            </span>
                            <input asp-for="TeacherName" class="form-control" placeholder="Full Name" />
                        </div>
                        <span asp-validation-for="TeacherName" class="text-danger d-block mb-2"></span>

                        <div class="mb-3 input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control" placeholder="Email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger d-block mb-2"></span>

                        <div class="mb-3 input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-building"></i>
                            </span>
                            <input asp-for="Department" class="form-control" placeholder="Department" />
                        </div>
                        <span asp-validation-for="Department" class="text-danger d-block mb-2"></span>

                        <button type="submit" class="btn btn-success w-100 mt-2">
                            <i class="fas fa-plus-circle me-1"></i>Create
                        </button>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none">
                    <i class="fas fa-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}